# React + Vite

This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.

Currently, two official plugins are available:

- [@vitejs/plugin-react](https://github.com/vitejs/vite-plugin-react/blob/main/packages/plugin-react) uses [Oxc](https://oxc.rs)
- [@vitejs/plugin-react-swc](https://github.com/vitejs/vite-plugin-react/blob/main/packages/plugin-react-swc) uses [SWC](https://swc.rs/)

## React Compiler

The React Compiler is not enabled on this template because of its impact on dev & build performances. To add it, see [this documentation](https://react.dev/learn/react-compiler/installation).

## Expanding the ESLint configuration

If you are developing a production application, we recommend using TypeScript with type-aware lint rules enabled. Check out the [TS template](https://github.com/vitejs/vite/tree/main/packages/create-vite/template-react-ts) for information on how to integrate TypeScript and [`typescript-eslint`](https://typescript-eslint.io) in your project.
</file>

<file path="SmartLogix/frontend/fron_smart_logix/src/App.css">
/* ==========================================
   ESTILOS GENERALES Y RESETEO
   ========================================== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
 
body {
  font-family: "Segoe UI", Arial, sans-serif;
  background: #140809;
  color: #f8d7da;
}
 
/* CONTENEDOR GENERAL */
.container {
  min-height: 100vh;
  background: linear-gradient(
    135deg,
    #140809,
    #230b0d,
    #3b0d11
  );
  padding: 40px;
}
 
/* ==========================================
   LOADING CON SPINNER ANIMADO
   ========================================== */
.inventory-loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background: #140809;
  gap: 20px;
}
 
.spinner {
  width: 50px;
  height: 50px;
  border: 5px solid rgba(239, 68, 68, 0.15);
  border-top-color: #ef4444;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
 
.inventory-loading h2 {
  font-size: 20px;
  color: #ef4444;
  font-weight: 500;
  letter-spacing: 0.5px;
}
 
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
 
/* ==========================================
   COMPONENTES GLOBALES (NAVBAR)
   ========================================== */
.nav-btn {
  background: #2a1114;
  border: 1px solid #4b1b20;
  color: #fca5a5;
  padding: 10px 18px;
  border-radius: 10px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  transition: 0.25s;
}
 
.nav-btn:hover {
  background: #5f1d25;
  color: white;
}
 
.nav-btn.active {
  background: rgba(239, 68, 68, 0.15);
  border-color: #ef4444;
  color: #f87171;
}
 
/* ==========================================
   ESTRUCTURA DE PÁGINAS
   ========================================== */
.inventory-container {
  width: 100%;
  max-width: 1450px;
  margin: 0 auto;
}
 
/* HEADER */
.inventory-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40px;
}
 
.inventory-header h1 {
  font-size: 42px;
  font-weight: 700;
  color: #ef4444;
  margin-bottom: 8px;
  text-shadow: 0 0 20px rgba(239, 68, 68, 0.25);
}
 
.inventory-header p {
  color: #fca5a5;
  font-size: 16px;
}
 
/* ==========================================
   BOTÓN LOGOUT
   ========================================== */
.logout-btn {
  background: linear-gradient(
    135deg,
    #dc2626,
    #991b1b
  );
  border: none;
  color: white;
  padding: 14px 22px;
  border-radius: 12px;
  cursor: pointer;
  font-size: 15px;
  font-weight: 600;
  transition: 0.3s;
}
 
.logout-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 20px rgba(220, 38, 38, 0.35);
}
 
/* ==========================================
   TARJETAS DE ESTADÍSTICAS
   ========================================== */
.inventory-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 40px;
}
 
.stat-card {
  background: rgba(40, 10, 12, 0.95);
  border: 1px solid #5f1d25;
  border-radius: 20px;
  padding: 30px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
  transition: 0.3s;
}
 
.stat-card:hover {
  transform: translateY(-4px);
  border-color: #ef4444;
  box-shadow: 0 12px 30px rgba(239, 68, 68, 0.12);
}
 
.stat-card h3 {
  color: #fca5a5;
  font-size: 16px;
  margin-bottom: 15px;
}
 
.stat-card p {
  font-size: 36px;
  font-weight: bold;
  color: #ef4444;
}
 
/* ==========================================
   TABLA Y BUSCADOR
   ========================================== */
.inventory-table-section {
  background: rgba(40, 10, 12, 0.98);
  border: 1px solid #5f1d25;
  border-radius: 20px;
  padding: 30px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
}
 
.table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25px;
}
 
.table-header h2 {
  font-size: 28px;
  color: white;
}
 
/* ==========================================
   INPUT BUSCADOR
   ========================================== */
.search-input {
  width: 280px;
  padding: 14px;
  border-radius: 12px;
  border: 1px solid #5f1d25;
  background: #1a0a0c;
  color: white;
  font-size: 14px;
  transition: 0.25s;
}
 
.search-input::placeholder {
  color: #d1a1a7;
}
 
.search-input:focus {
  outline: none;
  border-color: #ef4444;
  box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.12);
}
 
/* ==========================================
   TABLA
   ========================================== */
.inventory-table {
  width: 100%;
  border-collapse: collapse;
}
 
.inventory-table thead {
  background: #1a0a0c;
}
 
.inventory-table th {
  padding: 18px;
  text-align: left;
  color: #f87171;
  font-size: 15px;
  font-weight: 600;
}
 
.inventory-table td {
  padding: 18px;
  border-top: 1px solid #4b1b20;
  color: #f8d7da;
}
 
.inventory-table tbody tr {
  transition: 0.25s;
}
 
.inventory-table tbody tr:hover {
  background: rgba(127, 29, 29, 0.25);
}
 
/* ==========================================
   ELEMENTOS INTERNOS TABLA
   ========================================== */
.sku {
  color: #f87171;
  font-family: monospace;
  font-weight: bold;
}
 
/* ==========================================
   PILLS ESTADO
   ========================================== */
.status {
  padding: 7px 14px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
}
 
.available {
  background: rgba(220, 38, 38, 0.15);
  color: #f87171;
  border: 1px solid rgba(239, 68, 68, 0.25);
}
 
.unavailable {
  background: rgba(127, 29, 29, 0.25);
  color: #fecaca;
  border: 1px solid rgba(248, 113, 113, 0.2);
}
 
/* ==========================================
   SCROLLBAR BONITA
   ========================================== */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}
 
::-webkit-scrollbar-track {
  background: #1a0a0c;
}
 
::-webkit-scrollbar-thumb {
  background: #7f1d1d;
  border-radius: 20px;
}
 
::-webkit-scrollbar-thumb:hover {
  background: #dc2626;
}
 
/* ==========================================
   RESPONSIVE
   ========================================== */
@media (max-width: 1000px) {
  .inventory-header {
    flex-direction: column;
    align-items: stretch !important;
    gap: 20px;
  }
 
  .inventory-header div {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
 
  .inventory-stats {
    grid-template-columns: 1fr;
  }
 
  .table-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 15px;
  }
 
  .search-input {
    width: 100%;
  }
 
  .inventory-table-section {
    overflow-x: auto;
  }
}
</file>

<file path="SmartLogix/frontend/fron_smart_logix/src/App.jsx">
import "./App.css";
 
import {
  BrowserRouter,
  Routes,
  Route,
  Navigate,
} from "react-router-dom";
 
import Login from "./pages/loginPage";
import InventoryPage from "./pages/InventoryPage";
// Importamos las nuevas páginas
import OrdersPage from "./pages/OrdersPage";
import ShipmentsPage from "./pages/ShipmentsPage";
 
function ProtectedRoute({ children }) {
  const token = localStorage.getItem("token");
 
  if (!token) {
    return <Navigate to="/" replace />;
  }
 
  return children;
}
 
function App() {
  return (
    <BrowserRouter>
      <div className="container">
 
        <Routes>
 
          {/* Ruta Pública */}
          <Route
            path="/"
            element={<Login />}
          />
 
          {/* Rutas Protegidas de la aplicación */}
          <Route
            path="/inventory"
            element={
              <ProtectedRoute>
                <InventoryPage />
              </ProtectedRoute>
            }
          />
 
          <Route
            path="/orders"
            element={
              <ProtectedRoute>
                <OrdersPage />
              </ProtectedRoute>
            }
          />
 
          <Route
            path="/shipments"
            element={
              <ProtectedRoute>
                <ShipmentsPage />
              </ProtectedRoute>
            }
          />
 
        </Routes>
 
      </div>
    </BrowserRouter>
  );
}
 
export default App;
</file>

